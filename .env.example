# Copy to .env (gitignored) and fill in real values locally; never commit secrets.
# These are injected into config/yaml_configs/default.yaml via ${VAR} interpolation
# (see core/config/config_loader.py). In CI, provide them as repository secrets.

# The public Toolshop demo account is used by default (see config/yaml_configs/default.yaml),
# so no secret is needed to run the examples. Override only to use a different account:
# TOOLSHOP_EMAIL=
# TOOLSHOP_PASSWORD=

# Testiny test-management REST API key (https://app.testiny.io). Read directly by the
# `python -m tools.testiny` authoring tool (NOT injected into YAML config) and never logged.
TESTINY_API_KEY=
